# Aiven PostgreSQL connection string (Service overview -> Connection information)
# Format: postgres://avnadmin:PASSWORD@host.aivencloud.com:PORT/defaultdb?sslmode=require
DATABASE_URL=

# Aiven CA certificate (paste the full PEM, literal \n line breaks allowed).
# Leave empty to trust the chain without pinning (Aiven endpoints are signed
# by a public CA; in that case we fall back to sslmode=require without pinning).
PG_CA_CERT=

# Set to 1 to skip certificate verification (NOT recommended).
# PG_SSL_INSECURE=0

# Connection pool size (optional, default 10).
# PG_POOL_MAX=10

# HTTP port. Railway injects PORT automatically; leave empty in Railway vars.
# PORT=8443
